{
  "devCommand": "npm run dev",
  "build": {
    "env": {
      "VITE_SUPABASE_URL": "$VITE_SUPABASE_URL",
      "VITE_SUPABASE_ANON_KEY": "$VITE_SUPABASE_ANON_KEY"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
