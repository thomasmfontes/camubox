{
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/|node_modules/|@vite|@react-refresh|src/|.*\\..*).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/notify-expiring",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/cleanup-waiting-list",
      "schedule": "0 1 * * *"
    }
  ]
}
